# Map instrumentation aggregator outputs (generated artifacts).
bench/map-instrumentation-data/aggregate.json
bench/map-instrumentation-data/aggregate.md
bench/map-instrumentation-data/fixtures/aggregate.json
bench/map-instrumentation-data/fixtures/aggregate.md

# Map workload differential-test artifacts. The Zap project files
# under bench/map-workloads/ are checked in; everything generated by
# `zap build` and the instrumented binaries is per-run output and
# should not be committed.
bench/map-workloads/*/zap.lock
bench/map-workloads/*/instrumentation.json
bench/map-workloads/*/map-instrumentation.json
bench/map-workloads/*/map-instrumentation.jsonl
zap-deps
