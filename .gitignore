.DS_Store
.zig-cache/
.zig-global-cache/
zig-out/
zap-out/
.zap-cache/
zap-deps/
zap-deps-*.tar.xz
.claude/
.cog/
.opencode/
opencode.json
.mcp.json
/tmp/

# Map instrumentation aggregator outputs (generated artifacts).
bench/map-instrumentation-data/aggregate.json
bench/map-instrumentation-data/aggregate.md
bench/map-instrumentation-data/fixtures/aggregate.json
bench/map-instrumentation-data/fixtures/aggregate.md

# Concurrency-kernel benchmark build outputs (P1-J6 E1 re-measurement;
# the source and README are checked in, the binary is per-run output).
bench/concurrency-kernel/bench
bench/concurrency-kernel/*.o

# Concurrency-copy / move benchmark build outputs (P2-J9 E6 + P6-J1 re-run;
# sources, runners, and READMEs are checked in, builds are per-run output).
bench/concurrency-copy/bench
bench/concurrency-copy/.copy-bench-build/
bench/concurrency-copy/.move-bench-build/
bench/concurrency-copy/string-blob-bench
bench/concurrency-copy/.string-blob-bench-build/

# Map workload differential-test artifacts. The Zap project files
# under bench/map-workloads/ are checked in; everything generated by
# `zap build` and the instrumented binaries is per-run output and
# should not be committed.
bench/map-workloads/*/zap.lock
bench/map-workloads/*/instrumentation.json
bench/map-workloads/*/map-instrumentation.json
bench/map-workloads/*/map-instrumentation.jsonl
zap-deps
