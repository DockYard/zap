pub module Scalars {
  pub fn int() :: i64 {
    42
  }

  pub fn negative() :: i64 {
    -7
  }

  pub fn float() :: f64 {
    3.14
  }

  pub fn string() :: String {
    "hello"
  }

  pub fn boolean_true() :: Bool {
    true
  }

  pub fn boolean_false() :: Bool {
    false
  }

  pub fn hex() :: i64 {
    0xFF
  }
}
